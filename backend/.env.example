# General
PROJECT_NAME="Student Management System"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=student_management_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_management_db

# Security
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# CORS
# JSON-formatted list of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
